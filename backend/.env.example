# Copy this file to .env and fill in your SportApi7 RapidAPI details.
RAPIDAPI_KEY=your_rapidapi_key_here
RAPIDAPI_HOST=sportapi7.p.rapidapi.com
FOOTBALL_API_BASE_URL=https://sportapi7.p.rapidapi.com

# Current display season label.
SEASON_LABEL=25/26
FETCH_REMOTE_ENTITY_IMAGES=1

# Full sync safety valve: 0 = all pages, otherwise stop after this many pages
FULL_SYNC_PAGE_LIMIT=0
FULL_SYNC_PAGE_SIZE=100

# Incremental sync window: each page is one recent-events page per competition.
INCREMENTAL_LOOKBACK_PAGES=2

# Optional spacing between calls if your plan is sensitive to bursts
REQUEST_SLEEP_MS=200

# Set to 1 only if you want automatic background sync jobs on server startup.
ENABLE_SCHEDULER=0
